{
  "type": "module",
  "name": "bitrix24-mcp-bridge",
  "version": "0.1.1",
  "description": "MCP bridge server for Bitrix24 — exposes REST API access, tasks, projects and chat to MCP clients like Claude Code.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DarWiM/bitrix24-mcp-bridge.git"
  },
  "bin": {
    "bitrix24-bridge": "dist/cli.js",
    "bitrix24-mcp-bridge": "dist/cli.js"
  },
  "files": ["dist", "extension/dist", "docs/api-notes.md", "actions.example.json"],
  "scripts": {
    "test": "bun test",
    "dev": "bun run src/index.ts",
    "typecheck": "bunx tsc --noEmit && bunx tsc -p extension/tsconfig.json",
    "build:dist": "node scripts/build-dist.mjs",
    "build:ext": "bun run scripts/build-extension.ts",
    "build:ext:capture": "BITRIX_CAPTURE=1 bun run scripts/build-extension.ts",
    "build:ext:static": "node scripts/build-ext-static.mjs",
    "prepare": "node scripts/build-dist.mjs && node scripts/build-ext-static.mjs",
    "capture": "bun run src/capture-server.ts",
    "catalog:draft": "bun run src/catalog/build-catalog.ts captured.har > actions.draft.json",
    "catalog": "bun run src/catalog/build-catalog.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  }
}
